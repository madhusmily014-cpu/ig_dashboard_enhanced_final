# ── Instagram (fallback if no accounts added via dashboard) ───────────────────
ACCESS_TOKEN=your_default_instagram_access_token
ACCOUNT_ID=your_default_instagram_account_id

# ── Cloudinary (required for video uploads + auto-delete) ────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Telegram (required for alerts) ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-1001234567890

# ── Optional ──────────────────────────────────────────────────────────────────
DB_PATH=queue.db          # SQLite file path
POST_TIME_1=08:00         # First daily slot (UTC)
POST_TIME_2=17:00         # Second daily slot (UTC)
